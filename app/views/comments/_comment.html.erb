<div class="card-body" id="comment">
  <div class="d-flex align-items-start">
    <div>
      <strong><%= comment.user.user_name %></strong><br>
      <%= comment.content %><br>
      <small class="text-muted"><%= time_tag comment.updated_at %></small>
    </div>

    <% if policy(comment).destroy? %>
      <div class="ms-auto">
        <%= button_to "X", post_comment_path(comment.post, comment), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-outline-danger btn-sm" %>
      </div>
    <% end %>
  </div>
</div>