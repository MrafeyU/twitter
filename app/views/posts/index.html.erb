<div class="container my-4">
  <p style="color: green"><%= notice %></p>


  <% content_for :title, "Posts" %>
  <h1>Posts</h1>
    <div id="posts">
      <% @posts.each do |post| %>
        <%= render post %>
      <% end %>
      <div class="mt-3 d-flex gap-2">
      <%= paginate @posts %>
    </div>


  <!-- Action buttons -->
  <div class="mt-3 d-flex gap-2">
    <% if policy(Post).create? %>
      <%= link_to "New post", new_post_path,class: "btn btn-outline-primary btn-sm"  %>
    <% end %>
    <%= link_to "Back to Home", root_path, class: "btn btn-outline-primary btn-sm"  %>
  </div>


</div>
