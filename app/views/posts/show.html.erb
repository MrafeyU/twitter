<div class="container my-4">
  <!-- Render the post card -->
  <%= render @post %>

  <!-- Action buttons -->
  <div class="mt-3 d-flex gap-2">
    <% if current_user&.id == @post.user_id.to_i %>
      <%= link_to "Edit this post", edit_post_path(@post), class: "btn btn-outline-secondary btn-sm" %>
      <%= button_to "Destroy this post", @post, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-outline-danger btn-sm" %>
    <% end %>
    <%= link_to "Back to posts", posts_path, class: "btn btn-outline-primary btn-sm" %>
  </div>

  <!-- Comments Section -->
  <div class="mt-4">
    <h5>Comments</h5>
    <%= render "comments/comments", post: @post %>
  </div>
</div>