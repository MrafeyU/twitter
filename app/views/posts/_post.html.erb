
<div id="<%= dom_id post %>" class="card mb-4 shadow-sm">
  <div class="card-body">
    <!-- Post Header: Author and Time -->
    <div class="d-flex justify-content-between align-items-center mb-2">
      <div>
        <strong><%= post.user&.user_name || "Unknown Author" %></strong>
        <small class="text-muted">| <%= time_tag post.created_at, post.created_at.strftime("%b %d, %Y %H:%M") %></small>
      </div>
      <div>
        <small class="text-muted"><%= pluralize(post.views, "View") %></small>
      </div>
    </div>

    <!-- Post Title -->
    <h5 class="card-title"><%= post.title %></h5>

    <!-- Post Attachments -->
    <% if post.attachments.attached? %>
      <div class="mb-3 d-flex flex-wrap gap-2">
        <% post.attachments.each do |attachment| %>
          <%= image_tag attachment, class: "img-thumbnail", style: "max-height: 150px;" %>
        <% end %>
      </div>
    <% end %>

    <!-- Post Content -->
    <div class="card-text trix-content">
      <%= post.content %>
    </div>

    <!-- Optional: Buttons for show/edit/delete -->
    <div class="mt-3 d-flex gap-2">
      <%= link_to "Show this post", post_path(post), class: "btn btn-outline-primary btn-sm" %>
      <% if policy(post).edit? %>
        <%= link_to "Edit", edit_post_path(post), class: "btn btn-outline-secondary btn-sm" %>
        <%= button_to "Destroy", post, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-outline-danger btn-sm" %>
      <% end %>
    </div>
  </div>
</div>